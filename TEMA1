<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Veracruz: Restauración de un Paraíso Perdido</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- Chosen Palette: Energetic & Playful -->
    <!-- Application Structure Plan: The SPA is structured as a top-to-bottom narrative scroll. It begins with a hook (Hero), introduces the stakes (Biodiversity), details the problem with data (Crisis & Deforestation Chart), presents the solution (Restoration ROI), shows proof of concept (Case Studies), and ends with a call to action (Conclusion). This linear storytelling approach is designed to build an emotional and intellectual case for restoration, making complex information digestible and persuasive for a general audience. -->
    <!-- Visualization & Content Choices: 1. Biodiversity Overview: Goal: Inform. Method: Icon cards (Unicode + Tailwind). Justification: Quickly conveys the range of ecosystems. 2. Key Crisis Stats: Goal: Inform. Method: Big numbers. Justification: High impact for critical data points like species extinction. 3. Deforestation Hotspots: Goal: Compare/Analyze. Method: Bar Chart (Chart.js). Justification: Best for comparing hair loss across municipalities and identifying key problem areas. Includes required label wrapping and tooltip config. 4. Restoration ROI: Goal: Persuade. Method: Animated number counters (JS). Justification: Dynamically illustrates the powerful economic argument for restoration. 5. Process Flow: Goal: Organize. Method: Numbered list with styled HTML/Tailwind. Justification: Clearly presents the strategic recommendations in a step-by-step format. -->
    <!-- CONFIRMATION: NO SVG graphics used. NO Mermaid JS used. -->
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #F8F9FA;
            color: #212529;
        }
        .chart-container {
            position: relative;
            width: 100%;
            max-width: 800px;
            margin-left: auto;
            margin-right: auto;
            height: 450px;
            max-height: 60vh;
        }
        @media (max-width: 768px) {
            .chart-container {
                height: 400px;
            }
        }
        .stat-card {
            background-color: white;
            border-radius: 0.75rem;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            padding: 1.5rem;
            text-align: center;
            border-top: 4px solid #00B2A9;
        }
        .hero-bg {
            background-image: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('https://images.unsplash.com/photo-1589519160754-38645908db09?q=80&w=2070&auto=format&fit=crop');
            background-size: cover;
            background-position: center;
        }
        .loader {
            border: 4px solid #f3f3f3;
            border-top: 4px solid #00B2A9;
            border-radius: 50%;
            width: 32px;
            height: 32px;
            animation: spin 1s linear infinite;
            margin: 20px auto;
        }
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
    </style>
</head>
<body class="antialiased">

    <header class="bg-white/90 backdrop-blur-lg sticky top-0 z-50 shadow-md">
        <nav class="container mx-auto px-6 py-4 flex justify-between items-center">
            <h1 class="text-2xl font-bold text-[#006A4E]">Veracruz Resiliente</h1>
            <div class="hidden md:flex space-x-6 text-gray-700 font-medium">
                <a href="#crisis" class="hover:text-[#00B2A9] transition-colors">La Crisis</a>
                <a href="#datos" class="hover:text-[#00B2A9] transition-colors">Los Datos</a>
                <a href="#solucion" class="hover:text-[#00B2A9] transition-colors">La Solución</a>
                <a href="#accion" class="hover:text-[#00B2A9] transition-colors">Acción</a>
            </div>
        </nav>
    </header>

    <main>
        <section class="hero-bg text-white py-20 md:py-32">
            <div class="container mx-auto px-6 text-center">
                <h2 class="text-4xl md:text-6xl font-extrabold leading-tight mb-4">Un Tapiz de Vida Deshilachado</h2>
                <p class="text-lg md:text-xl max-w-3xl mx-auto text-gray-200">Visualizando la urgente necesidad y la increíble promesa de la restauración ecológica en Veracruz, el tercer estado más biodiverso de México.</p>
            </div>
        </section>

        <section id="intro" class="py-16 md:py-20">
            <div class="container mx-auto px-6">
                <div class="text-center max-w-3xl mx-auto">
                    <h3 class="text-3xl md:text-4xl font-bold text-[#006A4E] mb-4">De Glaciares a Arrecifes</h3>
                    <p class="text-lg text-gray-600 mb-12">La geografía única de Veracruz ha creado una cadena de ecosistemas interconectados, desde las cumbres heladas hasta la costa tropical. Esta riqueza es también su mayor vulnerabilidad.</p>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                    <div class="stat-card border-t-[#00A3E0]">
                        <span class="text-5xl">🏔️</span>
                        <h4 class="text-xl font-bold mt-4 mb-2">Bosques de Niebla</h4>
                        <p class="text-gray-600">Verdaderas "fábricas de agua", hoy restringidas a solo 135,271 hectáreas, vitales para la seguridad hídrica del estado.</p>
                    </div>
                    <div class="stat-card border-t-[#00B2A9]">
                        <span class="text-5xl">🌳</span>
                        <h4 class="text-xl font-bold mt-4 mb-2">Selva Alta Perennifolia</h4>
                        <p class="text-gray-600">El ecosistema más exuberante del planeta, hoy confinado a remanentes que suman 251,505 hectáreas.</p>
                    </div>
                    <div class="stat-card border-t-[#E87722]">
                        <span class="text-5xl">💧</span>
                        <h4 class="text-xl font-bold mt-4 mb-2">Ríos y Humedales</h4>
                        <p class="text-gray-600">El 30% del agua de México escurre por Veracruz, pero sus ríos, como el Coatzacoalcos, están gravemente contaminados.</p>
                    </div>
                    <div class="stat-card border-t-[#FFC425]">
                        <span class="text-5xl">🌊</span>
                        <h4 class="text-xl font-bold mt-4 mb-2">Manglares y Costas</h4>
                        <p class="text-gray-600">Fragmentados en más de 814 parches, estos escudos naturales están siendo "exprimidos" entre la urbanización y el mar.</p>
                    </div>
                </div>
            </div>
        </section>

        <section id="crisis" class="py-16 md:py-20 bg-white">
            <div class="container mx-auto px-6">
                <div class="text-center max-w-3xl mx-auto">
                    <h3 class="text-3xl md:text-4xl font-bold text-[#006A4E] mb-4">El Gran Desmoronamiento</h3>
                    <p class="text-lg text-gray-600 mb-12">Un asedio implacable de deforestación, contaminación y cambio climático está llevando a los ecosistemas y especies de Veracruz a un punto de no retorno. Las cifras revelan la magnitud de la crisis.</p>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
                    <div class="stat-card">
                        <p class="text-5xl md:text-6xl font-extrabold text-[#00B2A9]">541,000</p>
                        <h4 class="text-xl font-bold mt-4">Hectáreas Perdidas</h4>
                        <p class="text-gray-600 mt-2">De cobertura arbórea entre 2001 y 2024, una disminución del 17%.</p>
                    </div>
                    <div class="stat-card">
                        <p class="text-5xl md:text-6xl font-extrabold text-[#E87722]">73%</p>
                        <h4 class="text-xl font-bold mt-4">Conversión a Pastizales</h4>
                        <p class="text-gray-600 mt-2">Es la principal causa de deforestación a nivel nacional, un patrón que domina el paisaje veracruzano.</p>
                    </div>
                    <div class="stat-card">
                        <p class="text-5xl md:text-6xl font-extrabold text-[#D22630]">37</p>
                        <h4 class="text-xl font-bold mt-4">Especies en Peligro Crítico</h4>
                        <p class="text-gray-600 mt-2">Animales endémicos, que solo existen en Veracruz, están al borde de la extinción.</p>
                    </div>
                </div>
            </div>
        </section>

        <section id="datos" class="py-16 md:py-20">
            <div class="container mx-auto px-6">
                <div class="text-center max-w-3xl mx-auto">
                    <h3 class="text-3xl md:text-4xl font-bold text-[#006A4E] mb-4">Anatomía de la Deforestación</h3>
                    <p class="text-lg text-gray-600 mb-12">Los datos satelitales de Global Forest Watch (2001-2024) identifican los "puntos calientes" de la pérdida de cobertura arbórea. El sur del estado concentra la mayor parte de la destrucción, impulsada por la expansión de la frontera ganadera.</p>
                </div>
                <div class="bg-white p-6 md:p-8 rounded-lg shadow-xl">
                    <h4 class="text-xl font-semibold text-center mb-4">Pérdida de Cobertura Arbórea por Municipio (miles de ha)</h4>
                    <div class="chart-container">
                        <canvas id="deforestationChart"></canvas>
                    </div>
                </div>
            </div>
        </section>

        <section id="solucion" class="py-16 md:py-20 bg-white">
            <div class="container mx-auto px-6">
                <div class="text-center max-w-3xl mx-auto">
                    <h3 class="text-3xl md:text-4xl font-bold text-[#006A4E] mb-4">La Arquitectura de la Recuperación</h3>
                    <p class="text-lg text-gray-600 mb-12">La restauración ecológica es un nuevo paradigma que va más allá de conservar; busca reconstruir. Es una de las inversiones más rentables, generando beneficios económicos, ambientales y sociales simultáneamente.</p>
                </div>
                <div class="bg-gray-50 rounded-lg p-8 md:p-12 grid md:grid-cols-2 gap-8 items-center max-w-4xl mx-auto shadow-lg">
                    <div class="text-center md:text-left">
                        <h4 class="text-2xl md:text-3xl font-bold mb-2">El Dividendo de la Naturaleza</h4>
                        <p class="text-gray-700">Por cada dólar invertido en la restauración de bosques, se genera un retorno masivo para las comunidades locales y la sociedad en general.</p>
                    </div>
                    <div class="text-center">
                        <p class="text-gray-600 font-medium">Por cada</p>
                        <p class="text-6xl md:text-7xl font-extrabold text-[#006A4E] my-2">$1</p>
                        <p class="text-gray-600 font-medium">invertido, se generan</p>
                        <p class="text-6xl md:text-7xl font-extrabold text-[#00B2A9] my-2">$<span id="roi-min">7</span> - $<span id="roi-max">30</span></p>
                        <p class="text-gray-600 font-medium">en beneficios económicos.</p>
                    </div>
                </div>
            </div>
        </section>

        <section id="accion" class="py-16 md:py-20">
            <div class="container mx-auto px-6">
                <div class="text-center max-w-3xl mx-auto">
                    <h3 class="text-3xl md:text-4xl font-bold text-[#006A4E] mb-4">Un Plan Maestro para un Veracruz Resiliente</h3>
                    <p class="text-lg text-gray-600 mb-12">Los casos de éxito demuestran que la recuperación es posible. Una estrategia de inversión debe enfocarse en acciones clave para escalar estos éxitos.</p>
                </div>
                <div class="max-w-4xl mx-auto space-y-8">
                    <div class="flex items-start space-x-6">
                        <div class="flex-shrink-0 bg-[#00B2A9] text-white rounded-full h-12 w-12 flex items-center justify-center font-bold text-xl">1</div>
                        <div>
                            <h4 class="text-xl font-bold">Invertir a Escala de Paisaje</h4>
                            <p class="text-gray-700 mt-1">Crear "corredores de restauración" que conecten las montañas con la costa, reconociendo que la salud de los ríos y arrecifes depende de los bosques de las cuencas altas.</p>
                        </div>
                    </div>
                    <div class="flex items-start space-x-6">
                        <div class="flex-shrink-0 bg-[#E87722] text-white rounded-full h-12 w-12 flex items-center justify-center font-bold text-xl">2</div>
                        <div>
                            <h4 class="text-xl font-bold">Empoderar a Actores Locales</h4>
                            <p class="text-gray-700 mt-1">Canalizar recursos a organizaciones y comunidades locales que poseen el conocimiento, la confianza y el compromiso a largo plazo para asegurar el éxito de los proyectos.</p>
                        </div>
                    </div>
                    <div class="flex items-start space-x-6">
                        <div class="flex-shrink-0 bg-[#00A3E0] text-white rounded-full h-12 w-12 flex items-center justify-center font-bold text-xl">3</div>
                        <div>
                            <h4 class="text-xl font-bold">Vincular Restauración y Medios de Vida</h4>
                            <p class="text-gray-700 mt-1">Apoyar proyectos que creen alternativas económicas sostenibles (agroforestería, ecoturismo) para que las comunidades se conviertan en las principales defensoras del bosque restaurado.</p>
                        </div>
                    </div>
                </div>
                
                <div class="mt-20 bg-white p-8 rounded-lg shadow-xl max-w-4xl mx-auto">
                    <h3 class="text-2xl md:text-3xl font-bold text-[#006A4E] mb-6 text-center">✨ Descubre Tu Rol en la Restauración</h3>
                    <div class="flex flex-col md:flex-row gap-4 items-center justify-center">
                        <select id="role-selector" class="w-full md:w-1/2 p-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#00B2A9] focus:outline-none">
                            <option value="">-- Selecciona tu rol --</option>
                            <option value="Estudiante">Estudiante</option>
                            <option value="Agricultor/a">Agricultor/a</option>
                            <option value="Turista">Turista</option>
                            <option value="Residente Urbano/a">Residente Urbano/a</option>
                        </select>
                        <button id="generate-action-btn" class="w-full md:w-auto bg-[#00B2A9] text-white font-bold py-3 px-6 rounded-lg hover:bg-[#008a82] transition-colors disabled:bg-gray-400">
                            Generar Mis Acciones
                        </button>
                    </div>
                    <div id="gemini-response-container" class="mt-6 p-6 bg-gray-50 rounded-lg min-h-[150px] text-left">
                        <p class="text-gray-500 text-center">Tus acciones personalizadas aparecerán aquí...</p>
                    </div>
                </div>

            </div>
        </section>
    </main>

    <footer class="bg-[#212529] text-white py-8">
        <div class="container mx-auto px-6 text-center text-gray-400">
            <p>&copy; 2025 Veracruz Resiliente. El momento de actuar es ahora.</p>
            <p class="text-sm mt-2">Infografía basada en el informe "Veracruz: Un Tapiz de Vida Deshilachado".</p>
        </div>
    </footer>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const wrapLabel = (label) => {
                if (label.length <= 16) {
                    return label;
                }
                const words = label.split(' ');
                const lines = [];
                let currentLine = '';
                words.forEach(word => {
                    if ((currentLine + word).length > 16) {
                        lines.push(currentLine.trim());
                        currentLine = '';
                    }
                    currentLine += word + ' ';
                });
                lines.push(currentLine.trim());
                return lines;
            };

            const deforestationData = {
                labels: [
                    'Las Choapas', 'Uxpanapa', 'Tantoyuca', 
                    'Ozuluama de Mascareñas', 'Minatitlán', 'Jesús Carranza', 'Hidalgotitlán'
                ],
                data: [65.6, 29.2, 26.5, 24.6, 20.1, 19.8, 18.5]
            };

            const ctx = document.getElementById('deforestationChart').getContext('2d');
            const deforestationChart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: deforestationData.labels.map(wrapLabel),
                    datasets: [{
                        label: 'Pérdida (miles de ha)',
                        data: deforestationData.data,
                        backgroundColor: [
                            '#D22630', '#E87722', '#FFC425', '#A5C399',
                            '#00B2A9', '#00A3E0', '#5A7D9A'
                        ],
                        borderColor: '#ffffff',
                        borderWidth: 2,
                        borderRadius: 4,
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    indexAxis: 'y',
                    scales: {
                        x: {
                            beginAtZero: true,
                            grid: { color: '#e9ecef' },
                            ticks: { color: '#495057' },
                            title: {
                                display: true,
                                text: 'Pérdida de Cobertura Arbórea (miles de hectáreas)',
                                color: '#212529',
                                font: { weight: 'bold' }
                            }
                        },
                        y: {
                            grid: { display: false },
                            ticks: { color: '#495057' }
                        }
                    },
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: '#212529',
                            titleFont: { weight: 'bold' },
                            bodyFont: { size: 14 },
                            padding: 12,
                            cornerRadius: 6,
                            callbacks: {
                                title: function(tooltipItems) {
                                    const item = tooltipItems[0];
                                    let label = item.chart.data.labels[item.dataIndex];
                                    if (Array.isArray(label)) {
                                      return label.join(' ');
                                    } else {
                                      return label;
                                    }
                                },
                                label: function(context) {
                                    return ` ${context.dataset.label}: ${context.raw.toFixed(1)} kha`;
                                }
                            }
                        }
                    }
                }
            });

            const roiMinEl = document.getElementById('roi-min');
            const roiMaxEl = document.getElementById('roi-max');

            const animateValue = (element, start, end, duration) => {
                let startTimestamp = null;
                const step = (timestamp) => {
                    if (!startTimestamp) startTimestamp = timestamp;
                    const progress = Math.min((timestamp - startTimestamp) / duration, 1);
                    element.innerHTML = Math.floor(progress * (end - start) + start);
                    if (progress < 1) {
                        window.requestAnimationFrame(step);
                    }
                };
                window.requestAnimationFrame(step);
            };

            const roiSection = document.getElementById('solucion');
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        animateValue(roiMinEl, 0, 7, 1500);
                        animateValue(roiMaxEl, 0, 30, 2000);
                        observer.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.5 });

            if(roiSection) {
                observer.observe(roiSection);
            }

            const generateBtn = document.getElementById('generate-action-btn');
            const roleSelector = document.getElementById('role-selector');
            const responseContainer = document.getElementById('gemini-response-container');

            generateBtn.addEventListener('click', async () => {
                const selectedRole = roleSelector.value;
                if (!selectedRole) {
                    responseContainer.innerHTML = '<p class="text-red-500 text-center">Por favor, selecciona un rol primero.</p>';
                    return;
                }

                generateBtn.disabled = true;
                responseContainer.innerHTML = '<div class="loader"></div>';

                const prompt = `Actúa como un experto en conservación y ecología de Veracruz, México. Basado en los problemas ecológicos clave de Veracruz (deforestación para ganadería, contaminación de ríos como el Coatzacoalcos, y pérdida de manglares), genera una lista de 3 acciones concretas, prácticas y de alto impacto que un "${selectedRole}" puede tomar para ayudar en la restauración ecológica. Usa un tono positivo y motivador. Formatea la respuesta en HTML usando un h4 para cada acción y un párrafo p para la descripción. No incluyas nada antes de la primera etiqueta h4 ni después de la última etiqueta p.`;

                try {
                    const text = await callGemini(prompt);
                    responseContainer.innerHTML = text;
                } catch (error) {
                    responseContainer.innerHTML = `<p class="text-red-500 text-center">Lo sentimos, ocurrió un error al generar las acciones. Por favor, intenta de nuevo más tarde.</p>`;
                } finally {
                    generateBtn.disabled = false;
                }
            });

            async function callGemini(prompt, retries = 3, delay = 1000) {
                let chatHistory = [{ role: "user", parts: [{ text: prompt }] }];
                const payload = { contents: chatHistory };
                const apiKey = ""; 
                const apiUrl = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-05-20:generateContent?key=${apiKey}`;

                for (let i = 0; i < retries; i++) {
                    try {
                        const response = await fetch(apiUrl, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(payload)
                        });

                        if (!response.ok) {
                            throw new Error(`HTTP error! status: ${response.status}`);
                        }

                        const result = await response.json();
                        
                        if (result.candidates && result.candidates.length > 0 &&
                            result.candidates[0].content && result.candidates[0].content.parts &&
                            result.candidates[0].content.parts.length > 0) {
                            return result.candidates[0].content.parts[0].text;
                        } else {
                            throw new Error('Respuesta inesperada de la API.');
                        }
                    } catch (error) {
                        if (i === retries - 1) {
                            throw error;
                        }
                        await new Promise(res => setTimeout(res, delay * Math.pow(2, i)));
                    }
                }
            }
        });
    </script>
</body>
</html>
