    <script>
        // ========== QUIZ FUNCTIONALITY ==========
        function setupQuizzes() {
            const quizContainers = document.querySelectorAll('.quiz-options');
            quizContainers.forEach((container, index) => {
                const options = container.querySelectorAll('.quiz-option');
                const feedbackEl = document.getElementById(`feedback-${index + 1}`);
                const quizNum = index + 1;

                options.forEach(option => {
                    option.addEventListener('click', function() {
                        // Remove previous selections
                        options.forEach(o => o.classList.remove('selected', 'correct', 'incorrect'));
                        
                        // Mark selected and check answer
                        this.classList.add('selected');
                        const isCorrect = this.getAttribute('data-answer') === 'true';
                        
                        if (isCorrect) {
                            this.classList.add('correct');
                            feedbackEl.classList.add('show', 'feedback-correct');
                            updateProgress();
                        } else {
                            this.classList.add('incorrect');
                            feedbackEl.classList.add('show', 'feedback-incorrect');
                            feedbackEl.innerHTML = `<strong>✗ Intenta de nuevo.</strong> Relee la sección y considera la respuesta correcta.`;
                        }
                    });
                });
            });
        }

        // ========== PROGRESS TRACKING ==========
        let completedQuizzes = 0;
        const totalQuizzes = 4;

        function updateProgress() {
            completedQuizzes++;
            const percentage = Math.round((completedQuizzes / totalQuizzes) * 100);
            document.getElementById('progress-fill').style.width = percentage + '%';
            document.getElementById('progress-percent').textContent = percentage;

            if (completedQuizzes === totalQuizzes) {
                showAchievementBadge();
            }
        }

        function showAchievementBadge() {
            const badge = document.createElement('div');
            badge.innerHTML = '<span class="achievement-badge">🏆 ¡Experto en Restauración!</span>';
            badge.style.position = 'fixed';
            badge.style.bottom = '20px';
            badge.style.right = '20px';
            badge.style.zIndex = '100';
            badge.style.animation = 'slideIn 0.5s ease-out';
            document.body.appendChild(badge);

            setTimeout(() => {
                badge.style.opacity = '0';
                badge.style.transition = 'opacity 0.5s';
                setTimeout(() => badge.remove(), 500);
            }, 3000);
        }

        // ========== CHART SETUP ==========
        function setupChart() {
            const wrapLabel = (label) => {
                if (label.length <= 16) return label;
                const words = label.split(' ');
                const lines = [];
                let currentLine = '';
                words.forEach(word => {
                    if ((currentLine + word).length > 16) {
                        lines.push(currentLine.trim());
                        currentLine = '';
                    }
                    currentLine += word + ' ';
                });
                lines.push(currentLine.trim());
                return lines;
            };

            const deforestationData = {
                labels: [
                    'Las Choapas', 'Uxpanapa', 'Tantoyuca', 
                    'Ozuluama de Mascareñas', 'Minatitlán', 'Jesús Carranza', 'Hidalgotitlán'
                ],
                data: [65.6, 29.2, 26.5, 24.6, 20.1, 19.8, 18.5]
            };

            const ctx = document.getElementById('deforestationChart').getContext('2d');
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: deforestationData.labels.map(wrapLabel),
                    datasets: [{
                        label: 'Pérdida (miles de ha)',
                        data: deforestationData.data,
                        backgroundColor: [
                            '#D22630', '#E87722', '#FFC425', '#A5C399',
                            '#00B2A9', '#00A3E0', '#5A7D9A'
                        ],
                        borderColor: '#ffffff',
                        borderWidth: 2,
                        borderRadius: 4,
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    indexAxis: 'y',
                    scales: {
                        x: {
                            beginAtZero: true,
                            grid: { color: '#e9ecef' },
                            ticks: { color: '#495057' },
                            title: {
                                display: true,
                                text: 'Pérdida de Cobertura Arbórea (miles de hectáreas)',
                                color: '#212529',
                                font: { weight: 'bold' }
                            }
                        },
                        y: {
                            grid: { display: false },
                            ticks: { color: '#495057' }
                        }
                    },
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: '#212529',
                            titleFont: { weight: 'bold' },
                            bodyFont: { size: 14 },
                            padding: 12,
                            cornerRadius: 6,
                            callbacks: {
                                title: function(tooltipItems) {
                                    const item = tooltipItems[0];
                                    let label = item.chart.data.labels[item.dataIndex];
                                    return Array.isArray(label) ? label.join(' ') : label;
                                },
                                label: function(context) {
                                    return ` ${context.dataset.label}: ${context.raw.toFixed(1)} kha`;
                                }
                            }
                        }
                    }
                }
            });
        }

        // ========== ROI ANIMATION ==========
        function animateROI() {
            const roiMinEl = document.getElementById('roi-min');
            const roiMaxEl = document.getElementById('roi-max');

            const animateValue = (element, start, end, duration) => {
                let startTimestamp = null;
                const step = (timestamp) => {
                    if (!startTimestamp) startTimestamp = timestamp;
                    const progress = Math.min((timestamp - startTimestamp) / duration, 1);
                    element.innerHTML = Math.floor(progress * (end - start) + start);
                    if (progress < 1) {
                        window.requestAnimationFrame(step);
                    }
                };
                window.requestAnimationFrame(step);
            };

            const roiSection = document.getElementById('solucion');
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        animateValue(roiMinEl, 0, 7, 1500);
                        animateValue(roiMaxEl, 0, 30, 2000);
                        observer.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.5 });

            if(roiSection) {
                observer.observe(roiSection);
            }
        }

        // ========== TEACHER RESOURCES TOGGLE ==========
        function toggleTeacherContent() {
            const content = document.getElementById('teacher-content');
            const button = document.querySelector('.teacher-toggle');
            content.classList.toggle('open');
            button.textContent = content.classList.contains('open') 
                ? 'Cerrar Recursos' 
                : 'Abrir Recursos Completos';
        }

        // ========== INITIALIZATION ==========
        document.addEventListener('DOMContentLoaded', function() {
            setupQuizzes();
            setupChart();
            animateROI();
        });

        // Add CSS animation for badge
        const style = document.createElement('style');
        style.textContent = `
            @keyframes slideIn {
                from {
                    transform: translateX(400px);
                    opacity: 0;
                }
                to {
                    transform: translateX(0);
                    opacity: 1;
                }
            }
        `;
        document.head.appendChild(style);
    </script>
